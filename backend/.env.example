# DeutschPrep backend configuration (copy to .env; never commit real secrets — CLAUDE.md §6).

APP_ENV=dev

# --- LLM ---
# Operator-supplied Opus-class model id; the app never hardcodes it.
CLAUDE_MODEL=claude-opus-4-8
# How to reach a model: auto | claude_code | api_key | stub
#   auto        -> API key if set, else local Claude Code CLI (subscription), else offline stub
#   claude_code -> your personal Claude subscription via the `claude` CLI (no API key needed)
#   api_key     -> Anthropic API (requires ANTHROPIC_API_KEY below)
#   stub        -> offline deterministic stub
LLM_MODE=auto
CLAUDE_BIN=claude
# Leave ANTHROPIC_API_KEY unset to use claude_code/stub instead of the paid API.
# ANTHROPIC_API_KEY=sk-ant-...
LLM_MAX_RETRIES=2
LLM_TIMEOUT_S=60
LLM_MAX_OUTPUT_TOKENS=4096

# --- Infrastructure (optional for the local vertical slice) ---
# docker-compose provides these; the in-memory slice ignores them.
DATABASE_URL=postgresql+psycopg://deutschprep:deutschprep@postgres:5432/deutschprep
REDIS_URL=redis://redis:6379/0

# Comma-separated CORS origins (Vite dev server by default).
CORS_ORIGINS=["http://localhost:5173"]
