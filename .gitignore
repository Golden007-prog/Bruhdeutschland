/ilets/

# Build/audit scratch
*.tsbuildinfo

# Desktop launcher build artifacts (PyInstaller; dist/ already ignored above)
desktop/build/
desktop/*.spec

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
