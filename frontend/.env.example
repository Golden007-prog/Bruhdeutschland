# DeutschPrep hosted target — public config only (ADR-0003).
# Copy to .env.local for local dev. The anon key is PUBLIC by design and protected by Supabase RLS.
# NEVER put a Supabase service key, or any LLM API key, in here or in the build — LLM keys are BYOK
# and entered at runtime by each user (Settings → API Keys).

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# Vite base path for GitHub Pages. For a project repo this is "/<repo>/".
# For a user/org page (username.github.io) or a custom domain, use "/".
VITE_BASE_PATH=/Bruhdeutschland/
